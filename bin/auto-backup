#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
LOG_DIR="$REPO_ROOT/logs"
mkdir -p "$LOG_DIR"
LOG_FILE="$LOG_DIR/auto-backup-$(date +%Y%m).log"

exec >>"$LOG_FILE" 2>&1

echo "[$(date '+%Y-%m-%d %H:%M:%S %Z')] auto-backup start"
cd "$REPO_ROOT"

./bin/sync-hermes-backup

if ! git diff --quiet || ! git diff --cached --quiet || [[ -n "$(git ls-files --others --exclude-standard)" ]]; then
  git add .
  if ! git diff --cached --quiet; then
    git commit -m "backup: auto update $(date +%Y-%m-%d)"
    git push origin main
    echo "[$(date '+%Y-%m-%d %H:%M:%S %Z')] changes pushed"
  else
    echo "[$(date '+%Y-%m-%d %H:%M:%S %Z')] no staged changes after add"
  fi
else
  echo "[$(date '+%Y-%m-%d %H:%M:%S %Z')] no changes"
fi

echo "[$(date '+%Y-%m-%d %H:%M:%S %Z')] auto-backup end"
