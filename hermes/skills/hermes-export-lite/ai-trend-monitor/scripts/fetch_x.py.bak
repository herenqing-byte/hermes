#!/usr/bin/env python3
"""Fetch recent tweets from key AI people via Nitter RSS with Catclaw search fallback.

Optimized version:
- Nitter instance pre-check (parallel, 5s timeout)
- Concurrent account fetching via ThreadPoolExecutor
- Global timeout control (120s max)
- Reduced per-request timeouts
"""

import json
import ssl
import sys
import os
import re
import time
from datetime import datetime, timedelta, timezone
from collections import defaultdict
from concurrent.futures import ThreadPoolExecutor, as_completed
import urllib.request
import urllib.error
import xml.etree.ElementTree as ET

